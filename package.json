{
  "name": "balasevic-digitalni-spomenar",
  "version": "1.0.0",
  "description": "Digitalni spomenar posvećen Đorđu Balaševiću — pesniku, arhitekti emocija i vojvođanskom duhu.",
  "author": "VelDeep <veldeep@example.com>",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "npx serve . -s -l 3000",
    "build:css": "cleancss -o style.min.css style.css",
    "build:js": "terser main.js -o main.min.js -c -m",
    "build": "npm run build:css && npm run build:js",
    "validate": "npx html-validate \"**/*.html\"",
    "audit": "npx lighthouse http://localhost:3000 --view --output=html",
    "test:a11y": "npx axe http://localhost:3000 --exit"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.8.0",
    "clean-css-cli": "^5.6.3",
    "html-validate": "^8.17.0",
    "lighthouse": "^11.6.0",
    "serve": "^14.2.1",
    "terser": "^5.26.0"
  }
}
